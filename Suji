(function execute(inputs, outputs) {

gs.info("Target SQL Table: " + inputs.target_sql_control);

/* ════════════════════════════════
   FIELD MAP — No Duplicates
   ════════════════════════════════ */
var fieldMap = {
    'number':                          '[Control Activity Number]',
    'name':                            '[Control Activity Name]',
