'u_management_control_risk_rating':'[Management Control Risk Rating]',
 
/* next NEW FIELDS */
'owning_group':'[Owning group]',
'u_platform_technologies':'[Platform Technologies]',
'u_product_name':'[Product]',
'profile_type':'[Entity type]',
'u_pwc_reliance':'[PwC Reliance]',
'u_pwc_mazars_risk_rating':'[PWC/MAZARS Risk Rating]',
'u_rationale_for_interdependencies':'[Rationale for Interdependencies]',
'refers_item':'[Reference risk/control]',
'u_region':'[Region]'
/*  
'respondents':'[Respondents]',
'u_segment':'[Segment]',
'sys_updated_on':'[Updated]',
'sys_updated_by':'[Updated by]'NEW FIELDS  */
 
/* err NEW FIELDS
'u_sub_category':'[Sub Category]',
'u_testing_interdependencies':'[Testing Interdependencies]'
'u_third_party_name':'[Third Party Name]',
'type':'[Type]'*/
};
 
var fields = Object.keys(fieldMap);
var sqlStatements = [];
var batchBuffer = [];
var batchSize = 500;
var counter = 0;
 
/* Capture current time */
var now = new GlideDateTime().getValue();
 
/* Get last run */
var lastRun = gs.getProperty('sn_compliance.Control_last_run_time');
 
var gr = new GlideRecord('sn_compliance_control');
 
if (!lastRun) {
 
gs.info("First run detected → BULK load");
gr.query();
 
} else {
 
gs.info("Incremental run since: " + lastRun);
 
var q = gr.addQuery('sys_created_on', '>', lastRun);
q.addOrCondition('sys_updated_on', '>', lastRun);
 
gr.query();
}
 
while (gr.next()) {
 
var values = {};
 
for (var i = 0; i < fields.length; i++) {
 
var field = fields[i];
var val;
 
if (['item_function','profile','content','u_process','u_assurance_owner_new','u_accounts_financial_statement','u_application_name',
'u_assertions_controlled','u_audit_entities','attestation','assessment_method','state','status','u_automated_component',
'u_business_control_owner_coordinator','u_business_control_owner_new','u_business_control_owner_new','u_business_process_owner',
'u_business_it_distinction','category','classification','u_coe','content','u_control_operating_frequency','u_control_type','u_core_it_service',
'u_coso_components','u_coso_principles','u_countries_name','sys_created_on','sys_created_by','u_division',
'u_entity_process_distinction','u_iag_director','u_iag_smd','u_information_processing_objective','u_information_provided_by_itd',
'u_information_provided_by_ksf','u_itgc_only','u_legal_entities','u_platform_technologies','u_process','u_product_name',
'u_pwc_reliance','u_pwc_mazars_risk_rating','u_rationale_for_interdependencies','refers_item','u_region',
'respondents','u_segment','u_sub_category','u_sub_segment','u_third_party_name'].indexOf(field) !== -1) {
 
val = gr.getDisplayValue(field);
 
}
 
else if (['state','status'].indexOf(field) !== -1) {
 
val = gr.getDisplayValue(field);
 
}
 
else if (field === 'exempt') {
 
val = gr.getValue(field) === 'true' ? 'true' : 'false';
 
}
 
else if (field === 'refers_item.name' || field === 'refers_item.number') {
 
var refGR = gr.refers_item.getRefRecord();
 
if (refGR && refGR.isValidRecord()) {
 
val = field === 'refers_item.name'
? refGR.getValue('name')
: refGR.getValue('number');
 
} else {
 
val = null;
 
}
 
}
 
else {
 
val = gr.getValue(field);
 
}
 
val = val ? val.replace(/'/g,"''") : null;
values[field] = val;
 
}
 
var number = values['number'];
 
if (!number) {
gs.warn("Skipping record with missing number: " + gr.sys_id);
continue;
}
 
var updateSet = fields.filter(function(f){
return f !== 'number';
}).map(function(f){
return fieldMap[f] + " = " + (values[f] !== null ? "'" + values[f] + "'" : "NULL");
}).join(", ");
 
var insertCols = fields.map(function(f){ return fieldMap[f]; }).join(", ");
 
var insertVals = fields.map(function(f){
return values[f] !== null ? "'" + values[f] + "'" : "NULL";
}).join(", ");
 
var updateSql =
"UPDATE " + inputs.target_sql_control + "\n" +
"SET " + updateSet + "\n" +
"WHERE [Control Activity Number] = '" + number + "'";
 
var insertSql =
"INSERT INTO " + inputs.target_sql_control + " (" + insertCols + ")\n" +
"SELECT " + insertVals + "\n" +
"WHERE NOT EXISTS (SELECT 1 FROM " +
inputs.target_sql_control +
" WHERE [Control Activity Number] = '" + number + "')";
 
batchBuffer.push(updateSql);
batchBuffer.push(insertSql);
counter++;
 
/* Flush batch */
 
if (counter >= batchSize) {
 
sqlStatements.push(batchBuffer.join("\n"));
batchBuffer = [];
counter = 0;
 
}
 
}
 
/* Flush remaining */
 
if (batchBuffer.length > 0) {
 
sqlStatements.push(batchBuffer.join("\n"));
 
}
 
/* Send SQL to JDBC */
 
outputs.bulk_sql_query = sqlStatements.join("\n\n-- End of Batch --\n\n");
 
gs.info("Generated bulk SQL in " + sqlStatements.length + " batches.");
 
/* Update last run property */
 
gs.setProperty('sn_compliance.Control_last_run_time', now);
 
})(inputs, outputs);
