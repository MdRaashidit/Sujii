    'u_control_operating_frequency':   '[Control Operating Frequency]',
    'exempt':                          '[Exempt]',
    'refers_item.name':                '[Reference Risk_Control Name]',
    'refers_item.number':              '[Reference Risk_Control Number]',
    'u_accounts_financial_statement':  '[Accounts Financial Statement]',
    'active':                          '[Active]',
